CAREER_AI_PROVIDER=ollama
OLLAMA_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=180
CAREER_AI_TIMEOUT_MS=30000

# Hosted Bedrock Mantle/OpenAI-compatible inference.
# Store real values in AWS Secrets Manager for deployment, not in git.
# CAREER_AI_PROVIDER=bedrock
# BEDROCK_BASE_URL=https://bedrock-mantle.us-east-1.api.aws/v1
# BEDROCK_API_KEY=
# BEDROCK_MODEL=openai.gpt-oss-20b
# BEDROCK_TIMEOUT_MS=15000
# COMPATIBLE_MAX_TOKENS=500

# PDF generation
# Use the bundled Codex Python locally, or install reportlab in your deployment image.
PYTHON_BIN=/Users/brian/.cache/codex-runtimes/codex-primary-runtime/dependencies/python/bin/python3

# Slack app settings for interview collection, channel logging, and answer evals.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_BRIAN_USER_ID=
SLACK_USER_LOG_CHANNEL_ID=
SLACK_HUMAN_EVAL_CHANNEL_ID=
SLACK_MOCK_INTERVIEW_CHANNEL_ID=
SLACK_INTERVIEW_REQUEST_CHANNEL_ID=

# Brain/eval datastore. Local dev falls back to output/brain-store.json.
# Production uses DynamoDB.
# BRAIN_STORE=dynamodb
# BRAIN_TABLE_NAME=brian-dear-career-mcp-brain-prod
# BRAIN_ENTITY_INDEX_NAME=entityType-createdAt-index
# ADMIN_TOKEN=
# ORIGIN_SHARED_SECRET=

# Async Slack/eval/background jobs. Local dev runs inline when ASYNC_QUEUE_URL is blank.
# ASYNC_QUEUE_URL=
# ASYNC_WORKER_ENABLED=false

# PDF generation safety timeout.
# PDF_GENERATION_TIMEOUT_MS=12000

# Optional OpenAI fallback instead of Ollama:
# CAREER_AI_PROVIDER=openai
# OPENAI_API_KEY=your_key_here
# OPENAI_MODEL=
# OPENAI_TIMEOUT_MS=4000
